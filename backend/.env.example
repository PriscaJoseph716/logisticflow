NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/logisticsflow
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=lf_token
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:5173

# Render production example:
# NODE_ENV=production
# COOKIE_SECURE=true
# FRONTEND_URL=https://logisticflow.vercel.app
# JWT_SECRET can also fall back to JWT_ACCESS_SECRET if that is already set.
#
# Customer portal share links are generated in the browser from window.location.origin.
# CUSTOMER_PORTAL_URL / PORTAL_URL are optional (CORS / legacy only).
