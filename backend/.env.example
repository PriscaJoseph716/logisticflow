NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/logisticsflow
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=lf_token
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:5173
CUSTOMER_PORTAL_URL=http://localhost:5173

# Render production example:
# NODE_ENV=production
# COOKIE_SECURE=true
# FRONTEND_URL=https://app.logisticflow.app
# CUSTOMER_PORTAL_URL=https://portal.logisticflow.app
# JWT_SECRET can also fall back to JWT_ACCESS_SECRET if that is already set.
