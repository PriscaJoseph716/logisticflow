generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id          String       @id @default(uuid())
  businessId  String       @unique
  companyName String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  roles       Role[]
  assignments Assignment[]
}

model Role {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  permissions String   @default("[]")
  isSystem    Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

model User {
  id           String       @id @default(uuid())
  fullName     String
  email        String
  passwordHash String
  phone        String?
  role         String       @default("OWNER")
  roleId       String?
  customRole   Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  businessId   String
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignments  Assignment[]
  proofs       Proof[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@index([roleId])
}

model Assignment {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workerId    String
  worker      User      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String    @default("")
  status      String    @default("PENDING")
  dueDate     DateTime?
  proofs      Proof[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([businessId])
  @@index([workerId])
  @@index([status])
}

model Proof {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  mimeType     String
  createdAt    DateTime   @default(now())

  @@index([assignmentId])
}
